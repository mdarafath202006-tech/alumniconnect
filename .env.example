# ─── AlumniConnect Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string-generated-by-secrets.token_hex(32)

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=alumni_mentorship

# JWT
JWT_SECRET_KEY=another-long-random-secret-for-jwt

# Email (for verification & password reset)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI (optional – for chatbot)
OPENAI_API_KEY=

# Redis (for rate limiting & caching)
REDIS_URL=redis://localhost:6379/0
